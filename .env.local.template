# Copy this file to .env.local and fill in the REPLACE_ME values.
# .env.local is in .gitignore so it never gets committed.

# --- Anthropic (Claude Haiku) ---
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# --- eBay Browse API (you have these already) ---
EBAY_APP_ID=REPLACE_ME
EBAY_CERT_ID=REPLACE_ME

# --- Firebase CLIENT config (6 values from Project Settings > General > Your apps > Web) ---
REACT_APP_FIREBASE_API_KEY=AIzaSyREPLACE_ME
REACT_APP_FIREBASE_AUTH_DOMAIN=boboa-scanner.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=boboa-scanner
REACT_APP_FIREBASE_STORAGE_BUCKET=boboa-scanner.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
REACT_APP_FIREBASE_APP_ID=REPLACE_ME

# --- Firebase SERVER config (Admin SDK — used by /api/scan and /api/quality) ---
# Base64-encoded service account JSON (one long line, no newlines).
FIREBASE_SERVICE_ACCOUNT_B64=REPLACE_ME
# Same as REACT_APP_FIREBASE_STORAGE_BUCKET — used by server.
FIREBASE_STORAGE_BUCKET=boboa-scanner.appspot.com

# --- API Base URL ---
# Use /api for Vercel serverless functions (default).
# Use http://localhost:8080/v1 when running the Go scanner service locally.
REACT_APP_API_BASE_URL=http://localhost:8088/v1


# ============================================================
# SwibSwap / BoBoa Scanner v13 — environment variables
# Copy to .env.local for local dev. Add the same values to
# Vercel → Project → Settings → Environment Variables for prod.
# ============================================================

# --- Anthropic (Claude Haiku vision) ---
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# --- eBay Browse API ---
EBAY_APP_ID=REPLACE_ME
EBAY_CERT_ID=REPLACE_ME

# --- Firebase (CLIENT) — these are PUBLIC, safe to commit to JS bundle ---
REACT_APP_FIREBASE_API_KEY=REPLACE_ME
REACT_APP_FIREBASE_AUTH_DOMAIN=boboa-scanner.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=boboa-scanner
REACT_APP_FIREBASE_STORAGE_BUCKET=boboa-scanner.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
REACT_APP_FIREBASE_APP_ID=REPLACE_ME

# --- Firebase (SERVER / Admin SDK) — SECRET, never commit ---
# Generate at Firebase Console → Project Settings → Service Accounts →
# "Generate new private key". Then take the downloaded JSON and:
#   1. Base64-encode the entire file contents
#   2. Paste the result here as one line
# This avoids newline-escape headaches in Vercel's env UI.
FIREBASE_SERVICE_ACCOUNT_B64=REPLACE_ME

# Bucket name (no gs:// prefix). Usually matches STORAGE_BUCKET above.
FIREBASE_STORAGE_BUCKET=boboa-scanner.appspot.com

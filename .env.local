EBAY_CERT_ID=PRD-bdab3bf648d1-3fcf-43ff-86c0-d4bd

# ---------- Firebase Admin SDK (server-side Firestore + Storage writes) ----------
# Pre-filled from the service account JSON you uploaded earlier.
# To regenerate: Firebase Console → Project Settings → Service Accounts →
#   Generate new private key → base64-encode the JSON file.
FIREBASE_SERVICE_ACCOUNT_

# ---------- Firebase client SDK (PUBLIC config, safe to commit visually) ----------
# These are the values that ship in your JS bundle anyway. Embedded in
# public/index.html-style configs by other apps. Restricted by Firebase's
# own API key restrictions, not by being secret.
# Get all 6 from: https://console.firebase.google.com → boboa-scanner project →
#   ⚙ Project Settings → General tab → Your apps → SDK setup and configuration
REACT_APP_FIREBASE_API_KEY=AIzaSyDRX1VzWZEE5Tah9jgf7mApDxvQdsXGVOc
REACT_APP_FIREBASE_AUTH_DOMAIN=boboa-scanner.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=boboa-scanner
REACT_APP_FIREBASE_STORAGE_BUCKET=boboa-scanner.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=240561794325
REACT_APP_FIREBASE_APP_ID=1:240561794325:web:e797136d8f0c2e4dcd4d1c

# ---------- Auction cron auth (server-side, never exposed to client) ----------
# This needs to MATCH the value you set in Vercel's CRON_SECRET env var.
# If you set one earlier and didn't save a copy, you can rotate by removing
# it in Vercel + adding a new random value (use the PowerShell snippet I
# gave you earlier). For LOCAL dev, any random string ≥32 chars works since
# the cron only fires on Vercel.
CRON_SECRET=WEpeNfTZJl3gItPys241mrRtTvXHOOUblwHUXU9E0
